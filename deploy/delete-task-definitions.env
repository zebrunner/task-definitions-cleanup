AWS_REGION=

# Optional static credentials (leave empty to use EC2 IAM role)
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#AWS_SESSION_TOKEN=

DEFINITIONS_FILE=/data/definitions.csv
RESULT_FILE=/data/definitions.result.csv

WRITE_BACK=true

# both|deregister|delete
ACTION=deregister

# false/true
RETRY_FAILED_ONLY=false

# true/false (optional)
DRY_RUN=false

# API Calls per second (optional)
API_RPS=1
